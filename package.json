{
  "name": "chaos-mcp",
  "version": "1.2.0",
  "description": "On-demand micro-mutation sandbox for AI test verification — maps holes in unit tests by running isolated mutation testing via the Model Context Protocol",
  "type": "module",
  "bin": {
    "chaos-mcp": "./build/index.js"
  },
  "files": [
    "build/",
    "scripts/install.sh",
    "scripts/postinstall.js"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mutation-testing",
    "stryker",
    "mutmut",
    "test-coverage",
    "ai-tools",
    "cli"
  ],
  "license": "MIT",
  "author": "AraneaDev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AraneaDev/Chaos-MCP.git"
  },
  "homepage": "https://github.com/AraneaDev/Chaos-MCP#readme",
  "bugs": {
    "url": "https://github.com/AraneaDev/Chaos-MCP/issues"
  },
  "scripts": {
    "build": "tsc && npm run postbuild",
    "postbuild": "node -e \"const fs=require('fs');const p='./build/index.js';let c=fs.readFileSync(p,'utf-8');if(!c.startsWith('#!/usr/bin/env node')){fs.writeFileSync(p,'#!/usr/bin/env node\\n'+c);console.log('Shebang restored')}\" && node -e \"if(process.platform!=='win32')require('child_process').execSync('chmod +x ./build/index.js')\"",
    "start": "node ./build/index.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm run check",
    "version": "node scripts/sync-app-version.js && git add src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "check": "npm run build && npm run lint && npm run format:check && npm run test",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-vitest": "^0.5.4",
    "prettier": "^3.2.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
